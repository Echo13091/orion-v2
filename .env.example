# =====================================================
# Orion V2 example environment
# Copy to .env for local Docker deployment.
# Do not commit real secrets or private network details.
# =====================================================

ORION_ENV=local
ORION_VERSION=dev

ORION_BACKEND_PORT=5001
ORION_FRONTEND_PORT=3001
ORION_MQTT_PORT=1883

# Comma-separated frontend origins allowed to call the backend.
ORION_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://<JETSON-IP>:3001

# Optional. If set, POST /v1/control/* requires this token.
# Frontend integration can send it as X-Orion-Control-Token.
ORION_CONTROL_TOKEN=

NEXT_PUBLIC_BACKEND_URL=http://<JETSON-IP>:5001
BACKEND_INTERNAL_URL=http://127.0.0.1:5001

VISION_NODE_URL=http://<VISION-NODE-IP>:5000
VISION_NODE_FALLBACK_URL=
VISION_TIMEOUT=3.0

SPRINKLER_BASE_URL=http://<SPRINKLER-CONTROLLER-IP>:5000
THERMOSTAT_BASE_URL=http://<THERMOSTAT-CONTROLLER-IP>:5002
SPRINKLER_ZONE_OFFSET=-1
