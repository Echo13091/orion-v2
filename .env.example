# Orion V2 example environment
# Copy to .env and adjust for your local network.

ORION_ENV=local
ORION_VERSION=dev

# Service ports
ORION_BACKEND_PORT=5001
ORION_FRONTEND_PORT=3001
ORION_MQTT_PORT=1883

# Frontend -> backend
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001
BACKEND_INTERNAL_URL=http://127.0.0.1:5001

# CORS
ORION_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Optional local hardware-control protection.
# Leave blank for LAN/dev behavior. Set a strong value before exposing controls.
ORION_CONTROL_TOKEN=

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883

# Field controllers
SPRINKLER_BASE_URL=http://sprinkler-controller.local:5000
THERMOSTAT_BASE_URL=http://thermostat-controller.local:5002
SPRINKLER_ZONES=8
SPRINKLER_ZONE_OFFSET=-1

# Vision node
VISION_NODE_URL=http://vision-node.local:5000
VISION_NODE_FALLBACK_URL=
VISION_TIMEOUT=3.0

# Runtime persistence
ORION_EVENT_LOG_PATH=/app/memory/orion_events.jsonl

# AI / LLM
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mistral

# Weather
ORION_WEATHER_LOCATION=auto

# Thermostat bridge
ORION_THERMOSTAT_SYNC_INTERVAL_SECONDS=10
